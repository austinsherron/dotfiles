{
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "notify-terminal -t 🔔 Claude Code -m Please review changes"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "notify-terminal -t ✅ Claude Code -m Task completed successfully"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "save-plan",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "maybern-dev@maybern": true,
    "maybern-monitoring@maybern": true,
    "maybern-ticket-lifecycle@maybern": true
  }
}
